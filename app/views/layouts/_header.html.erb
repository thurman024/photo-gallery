<header style="background-color: #0075EB;" class="w-full sticky top-0 z-10">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <%= image_tag "logo.svg", alt: "Photo Gallery", class: "h-12 w-12" %>
